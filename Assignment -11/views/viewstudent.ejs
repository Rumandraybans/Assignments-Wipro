<!DOCTYPE html>
<html>
<head>

<title>View Student</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="container mt-5">

<h1>Student Details</h1>

<ul class="list-group">

<li class="list-group-item">Name: <%= student.name %></li>

<li class="list-group-item">Roll No: <%= student.rollno %></li>

<li class="list-group-item">Course: <%= student.course %></li>

<li class="list-group-item">Age: <%= student.age %></li>

<li class="list-group-item">Email: <%= student.email %></li>

<li class="list-group-item">City: <%= student.city %></li>

</ul>

</body>
</html>