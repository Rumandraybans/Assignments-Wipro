<!DOCTYPE html>
<html>
<head>

<title>Edit Student</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="container mt-5">

<h1>Edit Student</h1>

<form action="/students/update/<%= student._id %>" method="POST">

<input type="text" name="name" value="<%= student.name %>" class="form-control mb-3">

<input type="number" name="rollno" value="<%= student.rollno %>" class="form-control mb-3">

<input type="text" name="course" value="<%= student.course %>" class="form-control mb-3">

<input type="number" name="age" value="<%= student.age %>" class="form-control mb-3">

<input type="email" name="email" value="<%= student.email %>" class="form-control mb-3">

<input type="text" name="city" value="<%= student.city %>" class="form-control mb-3">

<button class="btn btn-success">Update Student</button>

</form>

</body>
</html>