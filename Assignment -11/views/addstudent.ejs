<!DOCTYPE html>
<html>
<head>

<title>Add Student</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="container mt-5">

<h1>Add Student</h1>

<form action="/students/add" method="POST">

<input type="text" name="name" placeholder="Name" class="form-control mb-3">

<input type="number" name="rollno" placeholder="Roll Number" class="form-control mb-3">

<input type="text" name="course" placeholder="Course" class="form-control mb-3">

<input type="number" name="age" placeholder="Age" class="form-control mb-3">

<input type="email" name="email" placeholder="Email" class="form-control mb-3">

<input type="text" name="city" placeholder="City" class="form-control mb-3">

<button class="btn btn-primary">Add Student</button>

</form>

</body>
</html>